# --- Google Gemini (optional; omit and use run_pipeline.py --skip-briefing if unused) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Nitan MCP (USCardForum) — see FINDINGS.md + official thread ---
# https://www.uscardforum.com/t/topic/450599
# Repo: https://github.com/nitansde/nitan-mcp  |  npm: @nitansde/mcp

# Stdio server. Use --python_path so nitan-mcp’s Cloudflare helpers use THIS venv
# (pip install -r requirements.txt includes cloudscraper + curl-cffi).
# MCP_SERVER_COMMAND=npx
# MCP_SERVER_ARGS=["-y","@nitansde/mcp@latest","--python_path","/ABS/PATH/TO/nitan-pod/.venv/bin/python"]

# Forum login (recommended; set in .env only, never commit):
# NITAN_USERNAME=your_forum_id
# NITAN_PASSWORD=your_forum_password
# TIME_ZONE=America/Los_Angeles

# Tool + args — run: python run_pipeline.py --list-mcp-tools
# MCP_EXTRACT_TOOL=discourse_list_top_topics
# MCP_EXTRACT_TOOL_ARGUMENTS={"period":"weekly","limit":5}

# MCP_SERVER_ENV_JSON={"NITAN_USERNAME":"...","NITAN_PASSWORD":"...","TIME_ZONE":"America/Los_Angeles"}

# --- Programmatic NotebookLM (optional; pip install -r requirements-integrations.txt) ---
# One-time: playwright install chromium && notebooklm login
# NOTEBOOKLM_NOTEBOOK_ID=
# NOTEBOOKLM_AUDIO_LANGUAGE=zh
# NOTEBOOKLM_AUDIO_INSTRUCTIONS=
# NOTEBOOKLM_AUDIO_FORMAT=deep_dive
# NOTEBOOKLM_AUDIO_LENGTH=default
# NOTEBOOKLM_GENERATION_TIMEOUT=600
# NOTEBOOKLM_SOURCE_WAIT_TIMEOUT=180
# NOTEBOOKLM_STORAGE_PATH=
# NOTEBOOKLM_HTTP_TIMEOUT=60

# --- SoundCloud (optional; for inline audio player on 美卡论坛) ---
# Register app: https://soundcloud.com/you/apps
# One-time: python soundcloud_upload.py login
# SOUNDCLOUD_CLIENT_ID=
# SOUNDCLOUD_CLIENT_SECRET=

# --- RSS Feed / Podcast Distribution (optional; for --generate-rss) ---
# PODCAST_COVER_ART_URL=https://github.com/lifan-builds/nitan-podcast/raw/main/assets/cover.jpg
# PODCAST_AUTHOR=Nitan Podcast
# PODCAST_OWNER_NAME=
# PODCAST_OWNER_EMAIL=
# PODCAST_LINK=https://lifan-builds.github.io/nitan-podcast/
# PODCAST_FEED_URL=https://lifan-builds.github.io/nitan-podcast/feed.xml
# PODCAST_CATEGORY=Technology

# --- Demo / CI without live MCP ---
# EXTRACTION_FIXTURE_PATH=fixtures/sample_extraction.json
